{
  "name": "@learning/ui-kit",
  "version": "1.4.0",
  "description": "Framework adapters and framework-neutral UI contracts",
  "repository": {
    "type": "git",
    "url": "https://github.com/example/learning-ui.git",
    "directory": "packages/ui-kit"
  },
  "type": "module",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "default": "./dist/vue.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": ["**/*.css"],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
