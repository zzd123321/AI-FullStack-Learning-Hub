{
  "core": {
    "color": {
      "$type": "color",
      "blue600": {
        "$value": { "colorSpace": "srgb", "components": [0.145, 0.314, 0.761], "hex": "#2550c2" }
      },
      "blue700": {
        "$value": { "colorSpace": "srgb", "components": [0.102, 0.231, 0.612], "hex": "#1a3b9c" }
      },
      "neutral50": {
        "$value": { "colorSpace": "srgb", "components": [0.976, 0.98, 0.988], "hex": "#f9fafc" }
      },
      "neutral900": {
        "$value": { "colorSpace": "srgb", "components": [0.071, 0.09, 0.153], "hex": "#121727" }
      },
      "white": {
        "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "hex": "#ffffff" }
      }
    },
    "space": {
      "$type": "dimension",
      "2": { "$value": { "value": 8, "unit": "px" } },
      "3": { "$value": { "value": 12, "unit": "px" } },
      "4": { "$value": { "value": 16, "unit": "px" } }
    },
    "radius": {
      "$type": "dimension",
      "medium": { "$value": { "value": 8, "unit": "px" } }
    }
  },
  "semantic": {
    "light": {
      "text": { "default": { "$type": "color", "$value": "{core.color.neutral900}" } },
      "surface": { "canvas": { "$type": "color", "$value": "{core.color.white}" } },
      "action": {
        "primary": {
          "background": { "$type": "color", "$value": "{core.color.blue600}" },
          "backgroundHover": { "$type": "color", "$value": "{core.color.blue700}" },
          "foreground": { "$type": "color", "$value": "{core.color.white}" }
        }
      }
    },
    "dark": {
      "text": { "default": { "$type": "color", "$value": "{core.color.neutral50}" } },
      "surface": { "canvas": { "$type": "color", "$value": "{core.color.neutral900}" } },
      "action": {
        "primary": {
          "background": { "$type": "color", "$value": "{core.color.blue600}" },
          "backgroundHover": { "$type": "color", "$value": "{core.color.blue700}" },
          "foreground": { "$type": "color", "$value": "{core.color.white}" }
        }
      }
    }
  },
  "component": {
    "button": {
      "paddingInline": { "$type": "dimension", "$value": "{core.space.4}" },
      "paddingBlock": { "$type": "dimension", "$value": "{core.space.2}" },
      "radius": { "$type": "dimension", "$value": "{core.radius.medium}" }
    }
  }
}
