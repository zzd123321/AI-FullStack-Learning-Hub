# 仅供本地 Docker Compose 使用；不要提交真实密码。
MYSQL_DATABASE=ai_learning_hub
MYSQL_USER=learning_app
MYSQL_PASSWORD=change-me-for-local-only
MYSQL_ROOT_PASSWORD=change-root-password-for-local-only
MYSQL_PORT=3306

# 仅本地学习使用。部署环境必须改为由密钥管理系统提供的随机 Base64 密钥。
JWT_SECRET=YWktbGVhcm5pbmctaHViLWxvY2FsLWRldmVsb3BtZW50LXNlY3JldC0zMi1ieXRlcw==
JWT_SECURE_COOKIE=false

# 可选：首次启动时自动创建或升级本地管理员。两项都为空时不会创建任何管理员。
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=change-this-local-admin-password
ADMIN_DISPLAY_NAME=本地管理员
